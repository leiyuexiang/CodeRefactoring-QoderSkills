<!-- 根 POM modules 模板 -->
<!-- 使用说明：将 {module} 替换为实际业务模块名，按需增减 module 条目 -->
<modules>
    <module>grp-common-boot</module>
    <module>{module1}-module</module>
    <module>{module2}-module</module>
    <!-- 按需添加更多业务模块 -->
</modules>

